{
	"name": "php",
	
	"_tags": {
		"context": "$[%_context_]",
		"subcontext": "$[%_subcontext_]",
		"variable": "$[%_context_]['[%_variable_]']",
		"subvariable": "$[%_subcontext_]['[%_variable_]']",
	},
	"language": {
		"open": "<?php ",
		"close": " ?>"
	},
	"replace": {
		"format": "echo htmlspecialchars( [%variable], ENT_QUOTES );"
	},
	"list": {
		"open": "foreach ( [%variable] as [%subcontext] ) {",
		"close": "}",
		"objectProperty": "echo htmlspecialchars( [%subvariable], ENT_QUOTES );",
		"primitive": "echo htmlspecialchars( [%subcontext], ENT_QUOTES );"
	},
	"control": {
		"arg" : {
			"variable": "$[%_context_]['[%_variable_]']",
			"value": "[%_value_]"
		},
		"ifelse": {
			"if": "if ( [%_condition_] ) {",
			"elseif": "else if ( [%_condition_] ) {",
			"else": "else {",
			"close": "}"
		},
		"conditions": {
			"unary": "[%_operator_][%_arg_]",
			"binary": "[%_arg_] [%_operator_] [%_arg_]"
		}
		
	}
}