
{
	"name": "handlebars",
	"variables": {
		"variable": "[%_variable_]",
		"subvariable": "[%_variable_]"
	},
	"language": {
		"open": "",
		"close": ""
	},
	"replace": {
		"format": "{{[%variable]}}"
	},
	"list": {
		"open": "{{#[%variable]}}",
		"close": "{{/[%variable]}}",
		"objectProperty": "{{[%subvariable]}}",
		"primitive": "{{.}}"
	},
	"control": {
		"ifTruthy": {
			"open": "{{#if [%variable]}}",
			"close": "{{/if}}"
		},
		"ifFalsy": {
			"open": "{{#unless [%variable]}}",
			"close": "{{/unless}}"
		},
		"ifEqual": {
			"open": "{{#if_equal [%variable] [%variable]}}",
			"close": "{{/if_equal}}"
		},
		"ifNotEqual": {
			"open": "{{#if_not_equal [%variable] [%variable]}}",
			"close": "{{/if_not_equal}}"
		},
		"else": {
			"open": "{{else}}"
		}
	}
}
