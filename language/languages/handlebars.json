
{
	"name": "handlebars",
	"_tag": {
		"variable": "[%_variable_]",
		"subvariable": "[%_variable_]",
		"condition": "[%variable] [%_operator_] [%variable]"
	},
	"language": {
		"open": "",
		"close": ""
	},
	"replace": {
		"format": "{{[%_variable_]}}"
	},
	"list": {
		"open": "{{#[%_variable_]}}",
		"close": "{{/[%_variable_]}}",
		"objectProperty": "{{[%_variable_]}}",
		"primitive": "{{.}}"
	},
	"control": {
		"arg" : {
			"identifier": "[%_variable_]",
			"value": "[%_value_]"
		},
		"ifelse": {
			"if": "{{#if [%_condition_] }}",
			"elseif": "{{#elseif [%_condition_] }}",
			"else": "{{else}}",
			"close": "{{/if}}"
		},
		"conditions": {
			"unary": "[%_operator_][%_arg_]",
			"binary": "[%_operator_] [%_arg_] [%_arg_]"
		}
	}
}